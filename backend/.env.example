# Backend environment — copy to backend/.env for local dev, or set these in
# Render (prod). Values shown are local-dev defaults / placeholders.

# --- required (app crashes without these) ---
MONGO_URL=mongodb://localhost:27017          # prod: MongoDB Atlas SRV string
DB_NAME=cloudtax_ws_pilot
JWT_SECRET=change-me-long-random-string       # prod: Render generates one
ADMIN_EMAIL=nim@cloudtax.ca
ADMIN_PASSWORD=CloudTax2026!                   # also used by seed.py
# SEED_PASSWORD=                               # optional alias for seed pwd

# --- environment / CORS ---
PRODUCTION=false                               # prod: true
FRONTEND_URL=http://localhost:3000             # prod: the Vercel URL
ALLOWED_ORIGINS=                               # prod: = FRONTEND_URL (CSV ok)
SHOW_DEV_FALLBACK_TOKENS=true                  # prod: false (else leaks tokens)

# --- email (Resend). Unset = emails are no-ops; login still works. ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=CloudTax

# --- AI document parsing. Unset = parsing disabled. ---
EMERGENT_LLM_KEY=

# --- S3 (optional). Unset = falls back to local disk (.local_storage). ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
PRESIGNED_URL_EXPIRATION=3600
