{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudTaxS3ObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectAcl",
        "s3:PutObjectAcl"
      ],
      "Resource": [
        "arn:aws:s3:::cloudtax-ws-pilot/*"
      ]
    },
    {
      "Sid": "CloudTaxS3BucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::cloudtax-ws-pilot"
      ]
    }
  ]
}
